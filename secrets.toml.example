# ─────────────────────────────────────────────────────────────────────────────
# BCW Magazzino — Streamlit secrets (Cloudflare R2 backend)
#
# HOW TO USE
#   • On Streamlit Cloud: app → Settings → Secrets → paste the block below
#     (without this comment header) and fill in the 4 blanks.
#   • Locally: copy this file to  .streamlit/secrets.toml  and fill it in.
#
# NEVER commit the real secrets.toml to Git. Only this *.example file is safe.
# ─────────────────────────────────────────────────────────────────────────────

BCW_STORAGE       = "s3"
BCW_S3_BUCKET     = "bcw-magazzino"                 # the R2 bucket name you create
BCW_S3_PREFIX     = ""                              # leave empty (optional sub-folder)
BCW_S3_ENDPOINT   = "https://<ACCOUNT_ID>.r2.cloudflarestorage.com"   # from R2 dashboard
AWS_ACCESS_KEY_ID     = "<R2_ACCESS_KEY_ID>"        # from R2 → Manage API Tokens
AWS_SECRET_ACCESS_KEY = "<R2_SECRET_ACCESS_KEY>"    # shown ONCE when you create the token
AWS_REGION        = "auto"                          # R2 requires the literal value: auto

BCW_WORKBOOK_NAME = "MAGAZZINO BCW fixed.xlsx"      # the object key of the register in the bucket

ANTHROPIC_API_KEY = "sk-ant-..."                    # for supplier-document extraction
